# 1. Navigate to your app folder
cd path/to/edustay-app

# 2. Initialize a new Git repository
git init

# 3. Add all files to staging
git add .

# 4. Commit the files
git commit -m "Initial commit of EduStay app"

# 5. Create a new repo on GitHub first (via github.com → New Repository)
#    Copy the HTTPS URL of your new repo, e.g. https://github.com/zanevdm03/edustay-app.git

# 6. Link your local repo to GitHub
git remote add origin https://github.com/zanevdm03/edustay-app.git

# 7. Push your code to GitHub
git branch -M main
git push -u origin main
